@* Modal de formulaire réutilisable (sans dépendance au JS Bootstrap). *@

@if (Visible)
{
    <div class="modal fade show d-block" tabindex="-1" role="dialog">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@Title</h5>
                    <button type="button" class="btn-close" @onclick="OnCancel" disabled="@Saving"></button>
                </div>
                <div class="modal-body">
                    @if (!string.IsNullOrEmpty(Error))
                    {
                        <div class="alert alert-danger">@Error</div>
                    }
                    @ChildContent
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="OnCancel" disabled="@Saving">Annuler</button>
                    <button class="btn btn-primary" @onclick="OnSave" disabled="@(Saving || SaveDisabled)">
                        @(Saving ? "Enregistrement…" : "Enregistrer")
                    </button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show"></div>
}

@code {
    [Parameter] public bool Visible { get; set; }
    [Parameter] public string? Title { get; set; }
    [Parameter] public string? Error { get; set; }
    [Parameter] public bool Saving { get; set; }
    [Parameter] public bool SaveDisabled { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public EventCallback OnSave { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }
}
